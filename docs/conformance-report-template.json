{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NEXUS-A2A Conformance Report",
  "description": "Auto-generated by tests/nexus_harness at session end.",
  "type": "object",
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "total":   { "type": "integer" },
    "passed":  { "type": "integer" },
    "failed":  { "type": "integer" },
    "skipped": { "type": "integer" },
    "errors":  { "type": "integer" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "use_case_id":     { "type": "string" },
          "scenario_title":  { "type": "string" },
          "poc_demo":        { "type": "string" },
          "scenario_type":   { "type": "string" },
          "requirement_ids": { "type": "array", "items": { "type": "string" } },
          "status":          { "type": "string", "enum": ["pass", "fail", "skip", "error", "pending"] },
          "message":         { "type": "string" },
          "duration_ms":     { "type": "number" }
        },
        "required": ["use_case_id", "status"]
      }
    }
  },
  "required": ["generated_at", "total", "passed", "failed", "results"]
}
