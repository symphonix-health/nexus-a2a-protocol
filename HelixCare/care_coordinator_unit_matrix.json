  {
    "use_case_id": "CC-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "tasks/sendSubscribe accepts patient journey task",
    "scenario_type": "positive",
    "requirement_ids": ["FR-CC-1"],
    "preconditions": ["care-coordinator loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "cc-test-001",
      "method": "tasks/sendSubscribe",
      "params": {
        "task": {
          "patient": {"patient_id": "P-CC-001", "name": "Margaret Evans", "age": 55, "gender": "female"},
          "chief_complaint": "Post-op care coordination after knee replacement",
          "journey_stage": "post_surgery"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["task_id", "trace_id", "resume_cursor"]},
    "error_condition": "none",
    "test_tags": ["care-coordinator", "unit", "positive", "tasks-sendsubscribe"]
  },
