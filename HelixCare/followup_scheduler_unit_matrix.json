[
  {
    "use_case_id": "FS-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "followup/schedule books post-discharge follow-up appointment",
    "scenario_type": "positive",
    "requirement_ids": ["FR-FOLLOWUP-1"],
    "preconditions": ["followup-scheduler loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "fs-test-001",
      "method": "followup/schedule",
      "params": {
        "task": {
          "patient": {"patient_id": "P-FS-001", "name": "Henry Clark", "age": 68, "gender": "male"},
          "chief_complaint": "Post-cardiac-catheterisation follow-up",
          "discharge_date": "2026-03-20",
          "followup_specialty": "cardiology",
          "urgency": "urgent"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["task_id", "patient_id", "method", "status"]},
    "error_condition": "none",
    "test_tags": ["followup-scheduler", "unit", "positive", "schedule"]
  },
