  {
    "use_case_id": "TH-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "telehealth/consult dispatches video consultation",
    "scenario_type": "positive",
    "requirement_ids": ["FR-TELEHEALTH-1"],
    "preconditions": ["telehealth-agent loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "th-test-001",
      "method": "telehealth/consult",
      "params": {
        "task": {
          "patient": {"patient_id": "P-TH-001", "name": "Carol James", "age": 38, "gender": "female"},
          "chief_complaint": "Recurring migraines",
          "consult_type": "video",
          "urgency": "routine"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["patient_id", "method", "status"]},
    "error_condition": "none",
    "test_tags": ["telehealth", "unit", "positive", "consult"]
  },
