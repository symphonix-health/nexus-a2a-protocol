[
  {
    "use_case_id": "GHARRA-POS-001",
    "scenario_title": "Valid GHARRA record admits route to triage agent",
    "poc_demo": "helixcare",
    "scenario_type": "positive",
    "agent": "triage-agent",
    "agent_url_key": "triage-agent",
    "gharra_record": {
      "agent_name": "triage.nhs.uk.health",
      "zone": "nhs.uk.health",
      "trust_anchor": "uk.health",
      "transport": {
        "endpoint": "http://localhost:8021/rpc",
        "protocol": "nexus-a2a",
        "protocol_versions": [
          "1.0",
          "1.1"
        ],
        "feature_flags": [
          "routing.v1"
        ]
      },
      "authentication": {
        "mtls_required": false,
        "cert_bound_tokens_required": false
      },
      "capabilities": [
        "FHIR.Patient.read",
        "triage.assess"
      ],
      "policy_tags": [
        "clinical"
      ],
      "jurisdiction": "UK",
      "status": "active",
      "federated": false
    },
    "test_tags": [
      "gharra",
      "positive",
      "triage",
      "route-admission"
    ],
    "requirement_ids": [
      "NEXUS-GHARRA-001",
      "NEXUS-GHARRA-002",
      "FR-1",
      "IR-1",
      "IR-2"
    ],
    "expected_result": {
      "admitted": true,
      "policy_result": "admit"
    },
    "notes": "Baseline positive: valid record with matching zone/anchor should be admitted."
  },
