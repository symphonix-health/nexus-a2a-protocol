[
  {
    "use_case_id": "CV-UNIT-0001",
    "poc_demo": "consent-verification-unit",
    "scenario_title": "Insurer initiates consent request and receives task cursor",
    "scenario_type": "positive",
    "agent": "insurer-agent",
    "requirement_ids": [
      "FR-40",
      "CR-7",
      "FR-3",
      "FR-2",
      "CR-1",
      "FR-11"
    ],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "cv-unit-0001",
      "method": "tasks/sendSubscribe",
      "params": {
        "task": {
          "patient": {
            "patient_id": "CV001",
            "name": "Thomas Adeyemi"
          },
          "request_type": "prior_authorisation",
          "procedure": "MRI brain with contrast",
          "clinical_justification": "Suspected intracranial space-occupying lesion"
        }
      }
    },
    "auth_mode": "jwt_hs256",
    "expected_http_status": 200,
    "expected_result": {
      "ok": true,
      "contains": [
        "task_id",
        "trace_id",
        "resume_cursor"
      ]
    },
    "error_condition": "none",
    "test_tags": [
      "consent-verification",
      "insurer",
      "unit",
      "positive",
      "subscribe"
    ]
  },
