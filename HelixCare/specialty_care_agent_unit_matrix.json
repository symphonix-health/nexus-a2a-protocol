    "use_case_id": "SC-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "specialty_care/manage_referral dispatches specialist referral",
    "scenario_type": "positive",
    "requirement_ids": ["FR-SPECIALTY-CARE-1"],
    "preconditions": ["specialty-care-agent loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "sc-test-001",
      "method": "specialty_care/manage_referral",
      "params": {
        "task": {
          "patient": {"patient_id": "P-SC-001", "name": "Robert Chen", "age": 62, "gender": "male"},
          "referral_type": "cardiology",
          "chief_complaint": "Chest pain on exertion",
          "urgency": "urgent"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["task_id", "patient_id", "method", "status"]},
    "error_condition": "none",
    "test_tags": ["specialty-care", "unit", "positive", "manage-referral"]
  },
