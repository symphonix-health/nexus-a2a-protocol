[
  {
    "use_case_id": "TMS-UNIT-0001",
    "poc_demo": "telemed-scribe-unit",
    "scenario_title": "Transcriber accepts telehealth consultation and returns task cursor",
    "scenario_type": "positive",
    "agent": "transcriber-agent",
    "requirement_ids": [
      "FR-30",
      "FR-8",
      "FR-11",
      "FR-2"
    ],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "tms-unit-0001",
      "method": "tasks/sendSubscribe",
      "params": {
        "task": {
          "patient": {
            "patient_id": "TP001",
            "name": "Sarah Mitchell",
            "age": 44,
            "gender": "female"
          },
          "chief_complaint": "follow-up for type 2 diabetes management",
          "vitals": {
            "bp_systolic": 138,
            "bp_diastolic": 86,
            "heart_rate": 74,
            "spo2": 98
          }
        }
      }
    },
    "auth_mode": "jwt_hs256",
    "expected_http_status": 200,
    "expected_result": {
      "ok": true,
      "contains": [
        "task_id",
        "trace_id",
        "resume_cursor"
      ]
    },
    "error_condition": "none",
    "test_tags": [
      "telemed-scribe",
      "transcriber",
      "unit",
      "positive",
      "subscribe"
    ]
  },
