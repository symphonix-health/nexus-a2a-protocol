[
  {
    "use_case_id": "CCM-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "ccm/monthly_review triggers chronic care monthly review",
    "scenario_type": "positive",
    "requirement_ids": ["FR-CCM-1"],
    "preconditions": ["ccm-agent loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "ccm-test-001",
      "method": "ccm/monthly_review",
      "params": {
        "task": {
          "patient": {"patient_id": "P-CCM-001", "name": "George Thompson", "age": 72, "gender": "male"},
          "chief_complaint": "Monthly chronic condition review",
          "conditions": ["type_2_diabetes", "hypertension", "COPD"],
          "review_month": "2026-03"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["patient_id", "method", "status"]},
    "error_condition": "none",
    "test_tags": ["ccm", "unit", "positive", "monthly-review"]
  },
