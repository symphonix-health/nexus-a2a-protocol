  {
    "use_case_id": "PHS-UNIT-0001",
    "poc_demo": "public-health-surveillance-unit",
    "scenario_title": "Hospital reporter surveillance/report returns result without 5xx",
    "scenario_type": "positive",
    "agent": "hospital-reporter",
    "requirement_ids": [
      "FR-50",
      "FR-9",
      "CR-4",
      "FR-2"
    ],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "phs-unit-0001",
      "method": "surveillance/report",
      "params": {
        "task": {
          "pathogen": "influenza_a",
          "region": "North West England",
          "week": "2025-W10",
          "case_counts": {
            "confirmed": 142,
            "suspected": 89,
            "deaths": 3
          }
        }
      }
    },
    "auth_mode": "jwt_hs256",
    "expected_http_status": 200,
    "expected_result": {
      "ok": true,
      "contains": [
        "status",
        "method"
      ]
    },
    "error_condition": "none",
    "test_tags": [
      "public-health",
      "hospital-reporter",
      "unit",
      "positive",
      "surveillance-report"
    ]
  },
