[
  {
    "use_case_id": "HV-UNIT-0001",
    "poc_demo": "helixcare",
    "scenario_title": "home_visit/dispatch schedules a home visit",
    "scenario_type": "positive",
    "requirement_ids": ["FR-HOME-VISIT-1"],
    "preconditions": ["home-visit-agent loaded in-process", "jwt configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "hv-test-001",
      "method": "home_visit/dispatch",
      "params": {
        "task": {
          "patient": {"patient_id": "P-HV-001", "name": "Dorothy Harris", "age": 82, "gender": "female"},
          "chief_complaint": "Post-surgery wound assessment",
          "visit_type": "wound_care",
          "address": "12 Oak Lane, Springfield"
        }
      }
    },
    "transport": "unit",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["patient_id", "method", "status"]},
    "error_condition": "none",
    "test_tags": ["home-visit", "unit", "positive", "dispatch"]
  },
