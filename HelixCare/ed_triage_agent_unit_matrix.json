    "scenario_title": "Chest pain triggers ESI-2 triage",
    "scenario_type": "positive",
    "requirement_ids": [
      "FR-10",
      "CR-3",
      "FR-2",
      "FR-11"
    ],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "edt-unit-0001",
      "method": "tasks/sendSubscribe",
      "params": {
        "task": {
          "patient": {
            "patient_id": "P001",
            "name": "John Smith",
            "age": 55,
            "gender": "male"
          },
          "chief_complaint": "chest pain radiating to left arm",
          "vitals": {
            "spo2": 96,
            "temp_c": 37.2,
            "heart_rate": 110,
            "bp_systolic": 160,
            "bp_diastolic": 95
          }
        }
      }
    },
    "auth_mode": "jwt_hs256",
    "expected_http_status": 200,
    "expected_result": {
      "ok": true,
      "contains": [
        "task_id",
        "trace_id",
        "triage_level",
        "patient_id",
        "rationale"
      ],
      "triage_level": "ESI-2"
    },
    "error_condition": "none",
    "test_tags": [
      "ed-triage",
      "unit",
      "positive",
      "triage-level",
      "esi-2",
      "chest-pain"
    ]
  },
