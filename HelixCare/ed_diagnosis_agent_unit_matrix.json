  {
    "use_case_id": "EDD-UNIT-0001",
    "poc_demo": "ed-diagnosis-unit",
    "scenario_title": "Chest pain assessment returns triage level and LLM rationale",
    "scenario_type": "positive",
    "requirement_ids": [
      "FR-20",
      "CR-3",
      "FR-2",
      "FR-4"
    ],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "edd-unit-0001",
      "method": "diagnosis/assess",
      "params": {
        "task_id": "task-edd-0001",
        "task": {
          "patient": {
            "patient_id": "P101",
            "name": "James Thompson",
            "age": 58,
            "gender": "male"
          },
          "chief_complaint": "crushing chest pain with left arm radiation",
          "vitals": {
            "spo2": 94,
            "temp_c": 37.1,
            "heart_rate": 115,
            "bp_systolic": 175
          }
        }
      }
    },
    "auth_mode": "jwt_hs256",
    "expected_http_status": 200,
    "expected_result": {
      "ok": true,
      "contains": [
        "patient_id",
        "triage_level",
        "triage_priority",
        "rationale",
        "patient_context"
      ],
      "triage_level": "ESI-2",
      "triage_priority": "EMERGENCY",
      "rationale_is_non_empty": true
    },
    "error_condition": "none",
    "test_tags": [
      "ed-diagnosis",
      "unit",
      "positive",
      "llm",
      "esi-2",
      "chest-pain"
    ]
  },
