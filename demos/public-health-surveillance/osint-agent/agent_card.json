{
  "name": "osint-agent",
  "description": "Fetches open-source intelligence headlines related to disease outbreaks and returns snippets for a given pathogen.",
  "url": "http://osint-agent:8052",
  "protocol": "NEXUS-A2A",
  "protocolVersion": "1.0",
  "version": "0.1.0",
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "multiTransport": false,
    "websocket": true
  },
  "authentication": {
    "type": "bearer",
    "scheme": "JWT",
    "requiredScopes": [
      "nexus:invoke"
    ]
  },
  "methods": [
    "tasks/send",
    "tasks/sendSubscribe",
    "tasks/get",
    "tasks/cancel",
    "tasks/resubscribe",
    "osint/headlines"
  ],
  "skills": [
    {
      "id": "osint-headlines",
      "name": "OSINT Outbreak Headlines",
      "description": "Returns mock news headlines about a specified pathogen outbreak."
    }
  ],
  "defaultInputModes": [
    "application/json"
  ],
  "defaultOutputModes": [
    "application/json"
  ]
}
