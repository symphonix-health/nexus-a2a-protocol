{
  "name": "NCPDP Gateway Agent",
  "protocol": "NEXUS-A2A",
  "protocolVersion": "1.0",
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "multiTransport": false,
    "websocket": false
  },
  "authentication": {
    "type": "bearer",
    "scheme": "JWT",
    "requiredScopes": [
      "nexus:invoke",
      "ncpdp.submit"
    ]
  },
  "profiles": [
    {
      "profileId": "health.ncpdp.telecom.d0",
      "version": "1.0.0"
    }
  ],
  "methods": [
    "tasks/send",
    "tasks/get",
    "tasks/cancel"
  ]
}
