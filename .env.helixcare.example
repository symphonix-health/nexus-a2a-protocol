# HelixCare AI Hospital - Environment Configuration
# Copy this file to .env and configure your deployment

# ═══════════════════════════════════════════════════════════════════
# Core Security
# ═══════════════════════════════════════════════════════════════════

# JWT Secret for HS256 token signing (REQUIRED)
# Generate with: openssl rand -base64 32
NEXUS_JWT_SECRET=super-secret-test-key-change-me-in-production

# DID Verification (optional, set to true for decentralized identity)
DID_VERIFY=false

# ═══════════════════════════════════════════════════════════════════
# AI/LLM Configuration
# ═══════════════════════════════════════════════════════════════════

# OpenAI API Key (required for diagnosis, summarization, consent analysis, surveillance)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Model Selection
OPENAI_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════════════
# Workflow Configuration
# ═══════════════════════════════════════════════════════════════════

# Human-in-the-Loop requirement for consent decisions
HITL_REQUIRED=true

# ═══════════════════════════════════════════════════════════════════
# Optional: OIDC Configuration (Enterprise Identity Management)
# ═══════════════════════════════════════════════════════════════════

# Keycloak Admin Credentials (if using Keycloak)
# KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Keycloak Database Password
# KC_DB_PASSWORD=keycloak-db-password

# OIDC Discovery URL (for RS256 JWT verification)
# OIDC_DISCOVERY_URL=http://keycloak:8080/realms/helixcare/.well-known/openid-configuration

# ═══════════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════════

# EHR Database Path (SQLite)
EHR_DB=/data/ehr.sqlite

# ═══════════════════════════════════════════════════════════════════
# Monitoring & Observability
# ═══════════════════════════════════════════════════════════════════

# Command Centre Update Interval (milliseconds)
UPDATE_INTERVAL_MS=2000

# ═══════════════════════════════════════════════════════════════════
# Development/Testing Options
# ═══════════════════════════════════════════════════════════════════

# Enable debug logging
# DEBUG=true

# Disable certain health checks for dev
# SKIP_HEALTH_CHECKS=false
