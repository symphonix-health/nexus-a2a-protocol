    "revision_history": [
      {
        "revision_version": "1.0",
        "author": "Clinical Pathways Team",
        "reason": "Initial structured knowledge asset creation from NICE NG51 and Surviving Sepsis Campaign 2021.",
        "source_update": "NICE NG51, SSC 2021",
        "changes": [
          "Encoded NEWS2-based risk stratification (red/amber/low) per NG51 section 1.4",
          "Added Sepsis Six bundle (3 in, 3 out) per UK Sepsis Trust protocol",
          "Encoded antimicrobial initiation within 1 hour per NG51 section 1.6",
          "Added IV fluid resuscitation and lactate monitoring per SSC 2021",
          "Added escalation pathway to critical care per NG51 section 1.10"
        ],
        "approved_by": "Chief Clinical Information Officer",
        "approval_date": "2026-03-15",
        "revision_date": "2026-03-15"
      }
    ],
