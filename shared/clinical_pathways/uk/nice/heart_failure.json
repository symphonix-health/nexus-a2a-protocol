{
  "pathway_id": "nice-ng106-heart-failure",
  "title": "Chronic Heart Failure in Adults: Diagnosis and Management",
  "version": "2.0",
  "status": "active",
  "source_authority": "NICE",
  "guideline_reference": "https://www.nice.org.uk/guidance/ng106",
  "country": "GB",
  "publication_date": "2018-09-12",
  "description": "NICE NG106 pathway for diagnosis and management of chronic heart failure in adults. Covers initial assessment, diagnostic investigations, pharmacological and non-pharmacological management, specialist referral, and monitoring.",
  "governance": {
    "sources": [
      {
        "authority": "NICE",
