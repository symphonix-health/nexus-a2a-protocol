{
  "pathway_id": "nice-ng28-diabetes-type2",
  "title": "Type 2 Diabetes in Adults: Management",
  "version": "1.0",
  "status": "active",
  "source_authority": "NICE",
  "guideline_reference": "https://www.nice.org.uk/guidance/ng28",
  "country": "GB",
  "publication_date": "2022-06-29",
  "description": "NICE NG28 pathway for management of type 2 diabetes in adults. Covers glycaemic control, cardiovascular risk management, complications screening, and escalation of pharmacotherapy.",
  "governance": {
