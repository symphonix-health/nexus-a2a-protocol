{
    // Editor
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    // Python
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },
    // Python Testing
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "tests",
        "-v"
    ],
    // Ruff (Linting & Formatting)
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.importStrategy": "fromEnvironment",
    "ruff.path": [
        "${workspaceFolder}/.venv/Scripts/ruff.exe"
    ],
    // File Watching & Search
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true
    },
    "search.exclude": {
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/variants": true
    },
    // Git
    "git.ignoreLimitWarning": true,
    "git.autofetch": true,
    // Docker
    "docker.showStartPage": false,
    // Chat
    "chat.openFile.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor"
    },
    "chat.tools.terminal.autoApprove": {
        "/^python -m venv \\.venv$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "rest-client.defaultHeaders": {
        "Accept": "application/json",
        "Content-Type": "application/json"
    },
    "rest-client.environmentVariables": {
        "$shared": {
            "protocolVersion": "1.0",
            "clientAgentId": "client-local",
            "recipientAgentId": "echo",
            "apiToken": "replace-me"
        },
        "local": {
            "baseUrl": "http://localhost:8000"
        },
        "dev": {
            "baseUrl": "https://dev.nexus.example.com"
        },
        "prod": {
            "baseUrl": "https://nexus.example.com"
        }
    },
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        }
    },
    "editor.codeActions.triggerOnFocusChange": true
}
