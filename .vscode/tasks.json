{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test: Run All",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "tests/",
        "-v"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Test: Current File",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "${file}",
        "-v"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint: Check All",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "ruff",
        "check",
        "src",
        "tests"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Format: Check All",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "ruff",
        "format",
        "--check",
        "src",
        "tests"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Format: Fix All",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "ruff",
        "format",
        "src",
        "tests"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Launch All Agents",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/launch_all_agents.py",
        "--with-gateway"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Launch Agents + Command Centre",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/launch_all_agents.py",
        "--with-backend"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Launch Agents + Backend + Gateway",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/launch_all_agents.py",
        "--with-gateway"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Run All Scenarios",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/run_helixcare_scenarios.py"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Run Gateway Scenario Pass",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/helixcare_scenarios.py",
        "--gateway",
        "http://localhost:8100",
        "--retry-mode",
        "fast",
        "--run",
        "telehealth_video_consult"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "HelixCare: Run Validation Suite",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/run_hc_validation.py"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Command Centre: Start",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "shared/command-centre/app/main.py"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Interpreter Sanity",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-c",
        "import sys; print(sys.executable)"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Start HelixCare Stack",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "-f",
        "docker-compose-helixcare.yml",
        "up",
        "-d"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Stop HelixCare Stack",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "-f",
        "docker-compose-helixcare.yml",
        "down"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "MCP Server: Start",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "tools/nexus_mcp_server.py"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Gateway: Start",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "uvicorn",
        "shared.on_demand_gateway.app.main:app",
        "--host", "0.0.0.0",
        "--port", "8100"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Gateway: Stop",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$p = Get-NetTCPConnection -LocalPort 8100 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty OwningProcess; if ($p) { Stop-Process -Id $p -Force; Write-Host \"Stopped gateway PID $p on port 8100\" } else { Write-Host \"No listening process on port 8100\" }"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Validate Bicep (What-If)",
      "type": "shell",
      "command": "azd",
      "args": [
        "provision",
        "--preview"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Deploy Infrastructure",
      "type": "shell",
      "command": "azd",
      "args": [
        "provision"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Deploy Application",
      "type": "shell",
      "command": "azd",
      "args": [
        "deploy"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Deploy All (Up)",
      "type": "shell",
      "command": "azd",
      "args": [
        "up"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: View Agent Logs (Command Centre)",
      "type": "shell",
      "command": "az",
      "args": [
        "containerapp",
        "logs",
        "show",
        "--name",
        "ca-${input:azureEnvironmentName}-command-centre-backend",
        "--resource-group",
        "rg-${input:azureEnvironmentName}",
        "--follow"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: View Agent Logs (Avatar)",
      "type": "shell",
      "command": "az",
      "args": [
        "containerapp",
        "logs",
        "show",
        "--name",
        "ca-${input:azureEnvironmentName}-clinician-avatar-agent",
        "--resource-group",
        "rg-${input:azureEnvironmentName}",
        "--follow"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Restart Command Centre",
      "type": "shell",
      "command": "az",
      "args": [
        "containerapp",
        "revision",
        "restart",
        "--name",
        "ca-${input:azureEnvironmentName}-command-centre-backend",
        "--resource-group",
        "rg-${input:azureEnvironmentName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Scale Agent (Interactive)",
      "type": "shell",
      "command": "az",
      "args": [
        "containerapp",
        "update",
        "--name",
        "${input:containerAppName}",
        "--resource-group",
        "rg-${input:azureEnvironmentName}",
        "--min-replicas",
        "${input:minReplicas}",
        "--max-replicas",
        "${input:maxReplicas}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Delete Resources (Down)",
      "type": "shell",
      "command": "azd",
      "args": [
        "down",
        "--force",
        "--purge"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Show Command Centre URL",
      "type": "shell",
      "command": "azd",
      "args": [
        "env",
        "get-values",
        "--output",
        "json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Azure: Open Command Centre",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$url = (azd env get-values --output json | ConvertFrom-Json).COMMAND_CENTRE_URL; if ($url) { Start-Process $url } else { Write-Host 'Command Centre URL not found. Run Azure: Deploy All first.' }"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "azureEnvironmentName",
      "type": "promptString",
      "description": "Azure environment name (e.g., dev, staging, prod)",
      "default": "helixcare-dev"
    },
    {
      "id": "containerAppName",
      "type": "promptString",
      "description": "Container App name (e.g., ca-helixcare-dev-triage-agent)",
      "default": "ca-helixcare-dev-"
    },
    {
      "id": "minReplicas",
      "type": "promptString",
      "description": "Minimum replicas",
      "default": "0"
    },
    {
      "id": "maxReplicas",
      "type": "promptString",
      "description": "Maximum replicas",
      "default": "5"
    }
  ]
}
