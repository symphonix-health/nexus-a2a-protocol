# Copy to .env and fill in for Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Or use OpenAI directly
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible endpoint (optional; defaults to https://api.openai.com/v1 when unset)
# Example local endpoint: http://127.0.0.1:18080/v1
OPENAI_BASE_URL=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Optional tuning for slower local-model inference
NEXUS_DIAGNOSIS_RPC_TIMEOUT_SECONDS=600
NEXUS_HEALTH_LATENCY_DEGRADED_MS=180000
NEXUS_HEALTH_LATENCY_MIN_SAMPLES=3

# ─── Notification Services ─────────────────────────────────────────
# SMTP (Gmail app-password flow)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=your-email@gmail.com

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── HelixCare Runtime ─────────────────────────────────────────────
HELIXCARE_RETRY_MODE=balanced
NEXUS_ON_DEMAND_GATEWAY_URL=http://localhost:8100
TRACE_SINK_URL=http://localhost:8099

# ─── Video Clinician Provider (Pluggable) ──────────────────────
# Supported values: local_gpu | did | sync
VIDEO_CLINICIAN_PROVIDER=local_gpu

# Shared timeout (seconds) for remote provider adapters
VIDEO_CLINICIAN_PROVIDER_TIMEOUT_SECONDS=15

# D-ID provider adapter endpoint + key
# Recommended: point this to your own backend adapter that normalizes
# D-ID responses into this shape: { speech: {...}, video: {...} }
DID_VIDEO_CLINICIAN_ENDPOINT=
DID_API_KEY=

# Sync provider adapter endpoint + key
# Recommended: point this to your own backend adapter that normalizes
# Sync responses into this shape: { speech: {...}, video: {...} }
SYNC_VIDEO_CLINICIAN_ENDPOINT=
SYNC_API_KEY=

# Local GPU renderer metadata (informational label)
LOCAL_GPU_VIDEO_RENDERER=threejs-lipsync
