# Copy to .env and fill in for Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Or use OpenAI directly
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible endpoint (optional; defaults to https://api.openai.com/v1 when unset)
# Example local endpoint: http://127.0.0.1:18080/v1
OPENAI_BASE_URL=

# Optional tuning for slower local-model inference
NEXUS_DIAGNOSIS_RPC_TIMEOUT_SECONDS=600
NEXUS_HEALTH_LATENCY_DEGRADED_MS=180000
NEXUS_HEALTH_LATENCY_MIN_SAMPLES=3
