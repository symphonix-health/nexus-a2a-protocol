# Copy to .env and fill in for Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Or use OpenAI directly
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible endpoint (optional; defaults to https://api.openai.com/v1 when unset)
# Example local endpoint: http://127.0.0.1:18080/v1
OPENAI_BASE_URL=

# Optional tuning for slower local-model inference
NEXUS_DIAGNOSIS_RPC_TIMEOUT_SECONDS=600
NEXUS_HEALTH_LATENCY_DEGRADED_MS=180000
NEXUS_HEALTH_LATENCY_MIN_SAMPLES=3

# ─── Notification Services ─────────────────────────────────────────
# SMTP (Gmail app-password flow)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=your-email@gmail.com

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── HelixCare Runtime ─────────────────────────────────────────────
HELIXCARE_RETRY_MODE=balanced
NEXUS_ON_DEMAND_GATEWAY_URL=http://localhost:8100
TRACE_SINK_URL=http://localhost:8099
