      "scenario_roles": {
        "primary": ["chest_pain_cardiac", "sepsis_deterioration", "trauma_multiinjury", "stroke_thrombolysis", "paediatric_respiratory", "mental_health_crisis", "obstetric_emergency", "renal_failure"],
