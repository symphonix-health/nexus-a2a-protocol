{
  "$schema": "nexus:agent-personas:v1",
  "description": "Maps each NEXUS agent to its clinical persona and IAM identity configuration. Agents are modelled as Entra ID Service Principals (or equivalent in other identity providers) assigned to security groups that control access delegation.",
  "iam_groups": {
    "nexus-clinical-high": {
      "description": "High-privilege clinical agents — direct patient care, prescribing, diagnosis. Entra role: clinician_service / RBAC level High.",
      "bulletrain_role": "clinician_service",
      "rbac_level": "High",
      "members": ["triage_agent", "diagnosis_agent", "imaging_agent", "pharmacy_agent", "discharge_agent", "primary_care_agent", "specialty_care_agent", "telehealth_agent", "clinician_avatar_agent"]
    },
    "nexus-clinical-medium": {
      "description": "Standard clinical support agents — observations, care coordination, home visits.",
      "bulletrain_role": "clinician_service",
      "rbac_level": "Medium",
      "members": ["bed_manager_agent", "followup_scheduler", "care_coordinator", "home_visit_agent", "ccm_agent", "transcriber_agent"]
    },
    "nexus-operations": {
      "description": "Operational and administrative agents — scheduling, records, bed management.",
      "bulletrain_role": "patient_service",
      "rbac_level": "Restricted",
      "members": ["followup_scheduler", "bed_manager_agent", "summariser_agent", "ehr_writer_agent"]
    },
    "nexus-governance": {
      "description": "Audit, consent, and compliance agents — read-only clinical data access.",
      "bulletrain_role": "auditor",
      "rbac_level": "High",
      "members": ["consent_analyser", "hospital_reporter", "central_surveillance", "audit_agent"]
    },
    "nexus-connector": {
      "description": "Integration bridge agents — FHIR/HL7 mediators, external gateways.",
      "bulletrain_role": "connector",
      "rbac_level": "High",
      "members": ["openhie_mediator", "insurer_agent", "provider_agent", "profile_registry_agent", "fhir_profile_agent", "x12_gateway_agent", "ncpdp_gateway_agent", "hl7v2_gateway_agent", "cda_document_agent", "dicom_imaging_agent"]
    },
    "nexus-intelligence": {
      "description": "Intelligence and surveillance agents — OSINT, public health reporting.",
      "bulletrain_role": "auditor",
      "rbac_level": "Restricted",
      "members": ["osint_agent"]
    }
  },
  "agents": {
    "triage_agent": {
      "port": 8021,
