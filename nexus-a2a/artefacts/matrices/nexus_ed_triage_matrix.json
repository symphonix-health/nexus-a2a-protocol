    "use_case_id": "UC-EDT-POS-0002",
    "poc_demo": "ed-triage",
    "scenario_title": "Chest pain ESI-2 triage via tasks/sendSubscribe",
    "scenario_type": "positive",
    "requirement_ids": ["FR-TRIAGE-1", "CR-3"],
    "preconditions": ["triage-agent running on port 8021", "jwt_secret_configured"],
    "input_payload": {
      "jsonrpc": "2.0",
      "id": "edt-pos-002",
      "method": "tasks/sendSubscribe",
      "params": {
        "task": {
          "patient": {"patient_id": "P001", "name": "John Smith", "age": 55, "gender": "male"},
          "chief_complaint": "chest pain radiating to left arm",
          "vitals": {"spo2": 96, "temp_c": 37.2, "heart_rate": 110, "bp_systolic": 160}
        }
      }
    },
    "transport": "https",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"ok": true, "contains": ["task_id", "triage_level"]},
    "expected_events": ["triage_complete"],
    "error_condition": "none",
    "test_tags": ["ed-triage", "chest-pain", "esi-2", "positive", "integration"]
  },
