    "use_case_id": "UC-LLM-POS-0004",
    "poc_demo": "local-llm-profile",
    "scenario_title": "consent-analyser responds to tasks/sendSubscribe with local LLM profile",
    "scenario_type": "positive",
    "requirement_ids": ["FR-LLM-PROFILE-3", "FR-CONSENT-1"],
    "preconditions": ["local model endpoint running on port 18080", "consent-analyser running on port 8043"],
    "input_payload": {
      "action": "jsonrpc",
      "url": "http://localhost:8043/rpc",
      "payload": {
        "jsonrpc": "2.0",
        "id": "llm-pos-004",
        "method": "tasks/sendSubscribe",
        "params": {
          "task": {
            "patient_id": "P001",
            "procedure": "biopsy",
            "consent_required": true
          }
        }
      }
    },
    "transport": "https",
    "auth_mode": "jwt",
    "expected_http_status": 200,
    "expected_result": {"result_has_keys": ["task_id"]},
    "error_condition": "none",
    "test_tags": ["local-llm-profile", "jsonrpc", "consent", "positive", "integration"]
  },
  {
    "use_case_id": "UC-LLM-POS-0005",
