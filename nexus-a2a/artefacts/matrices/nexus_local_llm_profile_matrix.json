    "requirement_ids": ["FR-LLM-PROFILE-3", "FR-TRIAGE-1"],
    "preconditions": ["local model endpoint running on port 18080", "triage-agent running on port 8021"],
    "input_payload": {
      "action": "jsonrpc",
