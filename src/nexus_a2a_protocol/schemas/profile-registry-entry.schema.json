{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/profile-registry-entry.schema.json",
  "title": "ProfileRegistryEntry",
  "type": "object",
  "required": [
    "profileId",
    "version",
    "adapterEndpoint"
  ],
  "properties": {
    "profileId": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "adapterEndpoint": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
